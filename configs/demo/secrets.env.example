# Kikubot DEMO secrets — copied to configs/demo/secrets.env by ./demo.sh.
#
# Everything here is safe defaults for the local-only demo. The ONLY thing you
# might change is the LLM key below.

# ── LLM provider key (OPTIONAL) ───────────────────────────────────────────
# Leave BLANK to run in demo-notice mode: the agent receives your email and
# replies with a "I'm alive, add a key for real answers" message — no API
# calls, no cost. Paste an Anthropic key to get real agent responses:
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Alternative: use OpenRouter. Just paste a key here (and leave ANTHROPIC_API_KEY
# blank) — demo.sh auto-detects it and switches the provider for you, no
# agents.yaml editing needed. Override the model with LLM_MODEL=... if you like.
OPENROUTER_API_KEY=

# ── Mailbox password ──────────────────────────────────────────────────────
# GreenMail runs with auth disabled, so NO password is needed. Leaving this
# blank also tells the SMTP client to skip authentication entirely (GreenMail's
# plaintext SMTP doesn't offer STARTTLS, and Go refuses to send credentials
# over an unencrypted connection). Leave it empty for the demo.
KIKU_EMAIL_PASSWORD=
