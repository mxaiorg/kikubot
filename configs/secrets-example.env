# Kikubot secrets — copy to configs/secrets.env and fill in the values that
# apply to your deployment. This file is loaded as env_file by every agent
# container in docker-compose.yml.
#
# DO NOT commit configs/secrets.env to git (it is gitignored).

# ── LLM provider keys (set at least one) ──────────────────────────────────
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Per-agent mailbox passwords ───────────────────────────────────────────
# Key naming: <UPPERCASED_LOCAL_PART>_EMAIL_PASSWORD.
# The container resolves the right entry by uppercasing the local-part of
# the AGENT_EMAIL env var that compose injects per service.
KIKU_EMAIL_PASSWORD=
BETA_EMAIL_PASSWORD=
GAMMA_EMAIL_PASSWORD=
DELTA_EMAIL_PASSWORD=

# ── Tool credentials (fill only those used by your agents) ────────────────

# WordPress
WEBSITE_URL=https://your-website-url.com
WORDPRESS_USER=admin
WORDPRESS_PASSWORD=

# Buffer
BUFFER_API_KEY=

# Xero
# Used by both xero_mcp (Custom Connection — AU/NZ/UK/US only) and xero_api
# (WebApp via direct REST — works anywhere). For xero_api you must also run
# cmd/xero-bootstrap once to seed data/<agent>/xero/tokens.json:
#   XERO_REDIRECT_URI=http://localhost:8080/callback   # must match portal config
#   go run ./cmd/xero-bootstrap -out data/<agent>/xero/tokens.json
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# Helpjuice
HELPJUICE_API_KEY=
HELPJUICE_ACCOUNT=

# Tika (document → text)
TIKA_URL=http://host.docker.internal:9998/tika/text

# mxMCP
MXMCP_API_KEY=

# Tavily
TAVILY_API_KEY=

# Vimeo
VIMEO_API_KEY=

# Nuki (smart lock — Web API token)
NUKI_API_TOKEN=

# Supabase (project URL + API key — anon or service-role)
SUPABASE_URL=
SUPABASE_API_KEY=

# WeatherAPI.com (https://www.weatherapi.com)
WEATHERAPI_KEY=
