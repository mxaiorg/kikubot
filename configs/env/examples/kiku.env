# This is an example of a coordenator agent

AGENT_NAME="Kiku"
AGENT_EMAIL=kiku@agents.example.com
EMAIL_PASSWORD="<PASSWORD>"

# comma separated list of domains (no '@') or emails addresses
WHITELIST="example.com,agents.example.com"
#BLACKLIST="agents.example.com"

#LLM_PROVIDER=anthropic
LLM_PROVIDER=openrouter

#LLM_MODEL=claude-opus-4-6
#LLM_MODEL=claude-sonnet-4-6
#LLM_MODEL=claude-haiku-4-5-20251001
#LLM_MODEL=anthropic/claude-opus-4.6
LLM_MODEL=anthropic/claude-sonnet-4.6
LLM_OPENROUTER_BACKUP=z-ai/glm-5.1

MAX_HISTORY_CHARS=300000

# Coordinator: each delegation to a peer (send_message + poll for reply) burns
# turns. Give Kiku headroom above the default 20 so multi-agent fan-outs can
# complete before we hit ErrMaxTurns.
MAX_TURNS=40

SYSTEM_PROMPT="Kiku, you are a helpful Coordenator Agent. You coordenate and execute tasks sent to you by users with the help of your coworkers, if there are any listed. Your role is to resolve and report back on tasks submitted by users, drawing on your tools and available coworkers as needed. You ALWAYS report back (report_tool) to the user when a task is concluded, can not be concluded, or you have questions for the user.
{{coworkers}}"
