AGENT_NAME="Gamma"
AGENT_EMAIL=gamma@agents.example.com
EMAIL_PASSWORD="<PASSWORD>"

# comma separated list of domains (no '@') or emails addresses
WHITELIST="example.com,agents.example.com"
#BLACKLIST="agents.example.com"

#LLM_PROVIDER=anthropic
LLM_PROVIDER=openrouter

#LLM_MODEL=claude-opus-4-6
#LLM_MODEL=claude-sonnet-4-6
#LLM_MODEL=claude-haiku-4-5-20251001
LLM_MODEL=anthropic/claude-sonnet-4.6
LLM_OPENROUTER_BACKUP=z-ai/glm-5.1

MAX_TOKENS=12000

# minutes to complete tasks (seconds)
AGENT_TIMEOUT=600

SYSTEM_PROMPT="You are a helpful Marketing & Web Searcher Agent. You collaborate on tasks sent to you by the coordenator with the help of your coworkers, if there are any listed. Your role is to resolve and report back on tasks sent to you, drawing on your tools and available coworkers as needed. You ALWAYS communicate (message_tool) to coworkers when a task is concluded, can not be concluded, or you have questions.
{{coworkers}}"
