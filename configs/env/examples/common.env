# This environment file is common to all agent containers.
# Per agent environment files overwrite individually defined variables.

# IMAP email server where agent accounts are hosted
EMAIL_SERVER=mail-agents.mxhero.com:993
SMTP_SERVER=mail-agents.mxhero.com
SMTP_PORT=587

# How much history to load (default 50,000 characters)
MAX_HISTORY_CHARS=200000

# Max LLM output tokens
MAX_TOKENS=6000

# Max chars per single tool result before truncation (default no limit)
#MAX_TOOL_RESULT_CHARS=20000

# comma separated list of domains (no '@') or emails addresses [SEE README.MD]
#WHITELIST="mxhero.com,agents.mxhero.com"
#BLACKLIST="agents.mxhero.com"

ANTHROPIC_API_KEY=<API-KEY-HERE>
OPENROUTER_API_KEY=<API-KEY-HERE>

# 5 minutes to complete tasks (300 seconds)
AGENT_TIMEOUT=300

# WORDPRESS CONFIG [SEE README.MD]
WEBSITE_URL=https://your-website-url.com
WORDPRESS_USER=admin
WORDPRESS_PASSWORD="<APPLICATION PASSWORD PASS HERE>"

# BUFFER
BUFFER_API_KEY=<API-KEY-HERE>

# XERO
XERO_CLIENT_ID=<ID-HERE>
XERO_CLIENT_SECRET=<API-SECRET-HERE>

# SALESFORCE
SALESFORCE_CLIENT_ID="<ID-HERE>"
SALESFORCE_CLIENT_SECRET="<API-SECRET-HERE>"
SALESFORCE_INSTANCE_URL=<URL-HERE>

# HELPJUICE
HELPJUICE_API_KEY=<API-KEY-HERE>
HELPJUICE_ACCOUNT=<ACCOUNT-HERE>

# TIKA (document to text service) [SEE README.MD]
TIKA_URL=http://host.docker.internal:9998/tika/text

# mxMCP API Key [SEE README.MD]
MXMCP_API_KEY=<API-KEY-HERE>